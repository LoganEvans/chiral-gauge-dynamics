@article{mai2021three,
    title = {Three-{Body} {Dynamics} of the a 1 ( 1260 ) {Resonance} from {Lattice} {QCD}},
    volume = {127},
    issn = {0031-9007, 1079-7114},
    url = {https://link.aps.org/doi/10.1103/PhysRevLett.127.222001},
    doi = {10.1103/PhysRevLett.127.222001},
    abstract = {In this Letter we have presented the first determination of the resonance parameters of the axial a1 resonance from QCD. For that, three milestones had to be reached. First, the finite-volume spectrum for a resonant three-hadron system was determined including threemeson operators in a lattice QCD calculation. Second, a three-body quantization condition including subsystems with spin and coupled channels was derived and applied to the finite-volume spectrum. Finally, the corresponding unitary three-body scattering amplitude was solved and analytically continued to the complex plane to determine the pole positions and branching ratios. We explored various forms of the short-range three-body force. In our main solution we found an overlap of the mass of the a1 with the phenomenological range, but substantially lower width.},
    number = {22},
    urldate = {2026-06-11},
    journal = {Physical Review Letters},
    author = {Mai, Maxim and Alexandru, Andrei and Brett, Ruairí and Culver, Chris and Döring, Michael and Lee, Frank X. and Sadasivan, Daniel and {GWQCD Collaboration}},
    month = nov,
    year = {2021},
    pages = {222001},
}



@book{krasnov2020formulations,
    edition = {1},
    title = {Formulations of {General} {Relativity}: {Gravity}, {Spinors} and {Differential} {Forms}},
    copyright = {https://www.cambridge.org/core/terms},
    isbn = {978-1-108-67465-2 978-1-108-48164-9},
    shorttitle = {Formulations of {General} {Relativity}},
    url = {https://www.cambridge.org/core/product/identifier/9781108674652/type/book},
    doi = {10.1017/9781108674652},
    abstract = {This monograph describes the different formulations of Einstein's General Theory of Relativity. Unlike traditional treatments, Cartan's geometry of fibre bundles and differential forms is placed at the forefront, and a detailed review of the relevant differential geometry is presented. Particular emphasis is given to general relativity in 4D space-time, in which the concepts of chirality and self-duality begin to play a key role. Associated chiral formulations are catalogued, and shown to lead to many practical simplifications. The book develops the chiral gravitational perturbation theory, in which the spinor formalism plays a central role. The book also presents in detail the twistor description of gravity, as well as its generalisation based on geometry of 3-forms in seven dimensions. Giving valuable insight into the very nature of gravity, this book joins our highly prestigious Cambridge Monographs in Mathematical Physics series. It will interest graduate students and researchers in the fields of theoretical physics and differential geometry.},
    urldate = {2026-06-11},
    publisher = {Cambridge University Press},
    author = {Krasnov, Kirill},
    month = nov,
    year = {2020},
}



