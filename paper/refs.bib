@article{riordan2010measurements,
    title = {Measurements of the {Electric} {Form} {Factor} of the {Neutron} up to {Q2}=3.4 {GeV2} using the {Reaction} {He3}(e,e'n)pp},
    volume = {105},
    issn = {0031-9007, 1079-7114},
