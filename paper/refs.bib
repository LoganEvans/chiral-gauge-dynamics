@article{kluth2006tests,
    title = {Tests of {Quantum} {Chromo} {Dynamics} at e{\textasciicircum}+e{\textasciicircum}- {Colliders}},
    volume = {69},
    issn = {0034-4885, 1361-6633},
    url = {http://arxiv.org/abs/hep-ex/0603011},
    doi = {10.1088/0034-4885/69/6/R04},
    abstract = {The current status of tests of the theory of strong interactions, Quantum Chromo Dynamics (QCD), with data from hadron production in e{\textasciicircum}+e{\textasciicircum}- annihilation experiments is reviewed. The LEP experiments ALEPH, DELPHI, L3 and OPAL have published many analyses with data recorded on the Z{\textasciicircum}0 resonance at sqrt(s)=91.2 GeV and above up to sqrt(s){\textgreater}200 GeV. There are also results from SLD at sqrt(s)=91.2 GeV and from reanalysis of data recorded by the JADE experiment at 14{\textless}sqrt(s){\textless}44 GeV. The results of studies of jet and event shape observables, of particle production and of quark gluon jet differences are compared with predictions by perturbative QCD calculations. Determinations of the strong coupling constant alpha\_S(M\_Z) from jet and event shape observables, scaling violation and fragmentation functions, inclusive observables from Z{\textasciicircum}0 decays, hadronic tau decays and hadron production in low energy e{\textasciicircum}+e{\textasciicircum}- annihilation are discussed. Updates of the measurements are performed where new data or improved calculations have become available. Finally, investigations of the gauge structure of QCD are summarised.},
    number = {6},
    urldate = {2026-06-11},
    journal = {Reports on Progress in Physics},
    author = {Kluth, Stefan},
    month = jun,
    year = {2006},
    note = {arXiv:hep-ex/0603011},
    keywords = {High Energy Physics - Phenomenology, High Energy Physics - Experiment},
    pages = {R04},
    annote = {Comment: 91 pages, 29 figures, revised version corresponds to paper published in journal, some references added, small inconsistency in QCD analysis of hadronic tau decays with tiny effect on results and no effect on conclusions fixed},
}



