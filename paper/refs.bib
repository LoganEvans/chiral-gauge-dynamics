@article{segarra2020neutron,
    title = {Neutron valence structure from nuclear deep inelastic scattering},
    volume = {124},
    issn = {0031-9007, 1079-7114},
    url = {http://arxiv.org/abs/1908.02223},
    doi = {10.1103/PhysRevLett.124.092002},
    abstract = {Mechanisms of spin-flavor SU(6) symmetry breaking in Quantum Chromodynamics (QCD) are studied via an extraction of the free neutron structure function from a global analysis of deep inelastic scattering (DIS) data on the proton and on nuclei from \$A = 2\$ (deuterium) to 208 (lead). Modification of the structure function of nucleons bound in atomic nuclei (known as the EMC effect) are consistently accounted for within the framework of a universal modification of nucleons in short-range correlated (SRC) pairs. Our extracted neutron-to-proton structure function ratio \$F\_2{\textasciicircum}n/F\_2{\textasciicircum}p\$ becomes constant for \$x\_B {\textbackslash}ge 0.6\$, equalling \$0.47 {\textbackslash}pm 0.04\$ as \$x\_B {\textbackslash}rightarrow 1\$, in agreement with theoretical predictions of perturbative QCD and the Dyson Schwinger equation, and in disagreement with predictions of the Scalar Diquark dominance model. We also predict \$F\_2{\textasciicircum}\{{\textasciicircum}3{\textbackslash}mathrm\{He\}\}/F\_2{\textasciicircum}\{{\textasciicircum}3{\textbackslash}mathrm\{H\}\}\$, recently measured, yet unpublished, by the MARATHON collaboration, the nuclear correction function that is needed to extract \$F\_2{\textasciicircum}n/F\_2{\textasciicircum}p\$ from \$F\_2{\textasciicircum}\{{\textasciicircum}3{\textbackslash}mathrm\{He\}\}/F\_2{\textasciicircum}\{{\textasciicircum}3{\textbackslash}mathrm\{H\}\}\$, and the theoretical uncertainty associated with this extraction.},
    number = {9},
    urldate = {2026-06-11},
    journal = {Physical Review Letters},
    author = {Segarra, E. P. and Schmidt, A. and Kutz, T. and Higinbotham, D. W. and Piasetzky, E. and Strikman, M. and Weinstein, L. B. and Hen, O.},
    month = mar,
    year = {2020},
    note = {arXiv:1908.02223 [nucl-th]},
    keywords = {High Energy Physics - Phenomenology, Nuclear Theory, High Energy Physics - Experiment, Nuclear Experiment},
    pages = {092002},
    annote = {Comment: Published in PRL. 6 pages, 4 figures and on-line supplementary materials},
}



